rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Users Collection
    match /users/{userId} {
      // Allow searching by phone/email to connect guardians
      allow get: if true;
      allow list: if request.auth != null; 
      
      // Users can only write to their own profile
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (request.auth.uid == userId || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isSosActive', 'lastLocation', 'battery_level']));
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // 2. OTP Collection (Used for Login & Password Resets)
    match /email_otps/{email} {
      // Allow unauthenticated users to request/verify codes
      allow get, create, update, delete: if true;
    }

    // 3. Chats & Messages
    match /chats/{chatId} {
      allow read, write: if request.auth != null && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null;
      
      match /messages/{msgId} {
        allow read, write: if request.auth != null;
      }
      
      match /live_locations/{locId} {
        allow read, write: if request.auth != null;
      }

      match /monitoring/{monId} {
        allow read, write: if request.auth != null;
      }
    }

    // 4. Global Location Tracking (for SOS)
    match /locations/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Default: Secure everything else
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
